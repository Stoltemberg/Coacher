ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=hdQlfaVzhr2e2ag3UfX3
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_TIMEOUT=15
ELEVENLABS_STABILITY=0.30
ELEVENLABS_SIMILARITY_BOOST=0.85
ELEVENLABS_STYLE=0.40
ELEVENLABS_USE_SPEAKER_BOOST=true

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# all = fala tudo que passar no filtro do app
# smart = fala so dicas importantes e corta ruido neutro
# minimal = fala quase so alertas criticos e objetivos
# off = nunca envia audio pro ElevenLabs
COACHER_TTS_MODE=smart

# 0 = sem limite. Qualquer numero > 0 limita a soma de caracteres
# enviados ao ElevenLabs durante a sessao atual.
COACHER_TTS_SESSION_CHAR_BUDGET=0

# Feed remoto opcional de conhecimento para enriquecer a base local.
# Pode ser uma URL HTTP(S) que retorne JSON ou um caminho local para um arquivo JSON.
COACHER_KNOWLEDGE_FEED_URL=

# Quanto tempo manter o feed remoto em cache antes de tentar atualizar de novo.
COACHER_KNOWLEDGE_FEED_TTL_HOURS=6
